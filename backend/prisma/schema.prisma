generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  phone            String?        @unique
  email            String?        @unique
  passwordHash     String?
  name             String
  class            Int
  board            String
  language         String         @default("hi")
  tier             String         @default("free")
  examDate         DateTime?
  studyHoursPerDay Int            @default(4)
  createdAt        DateTime       @default(now())

  doubts           Doubt[]
  studyPlan        StudyPlan?
  weaknesses       WeaknessMap[]
  sessions         StudySession[]
  lessonSessions   LessonSession[]
}

model Doubt {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  questionText     String
  questionAudio    String?
  subject          String
  chapter          String?
  aiResponse       String
  audioResponse    String?
  conceptsTagged   String[]
  wasHelpful       Boolean?
  escalatedToHuman Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model WeaknessMap {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  subject       String
  chapter       String
  concept       String
  weaknessScore Float
  lastAttempted DateTime
  attemptCount  Int      @default(0)
  wrongCount    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, subject, chapter, concept])
}

model StudyPlan {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  planData      Json
  weeklyTarget  Int
  currentStreak Int      @default(0)
  lastUpdated   DateTime @updatedAt
}

model StudySession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  subject         String
  durationMinutes Int
  topicsCovered   String[]
  date            DateTime @default(now())
}

model OtpRecord {
  id        String   @id @default(uuid())
  phone     String
  otp       String   // bcrypt hash of the 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model ChapterContent {
  id                String   @id @default(uuid())
  class             Int
  board             String   @default("CBSE")
  subject           String
  chapterNumber     Int
  chapterName       String
  concepts          String[]
  textbookQuestions Json
  keyFacts          String[]
  estimatedMinutes  Int
  difficulty        String
  pdfS3Key          String?
  processedAt       DateTime @default(now())

  @@unique([class, board, subject, chapterNumber])
}

model LessonSession {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  chapterId           String
  chapterName         String
  subject             String
  currentTaskIndex    Int       @default(0)
  conversationHistory Json
  status              String    @default("active")
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
}
